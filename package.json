{
  "devDependencies": {
    "prettier": "3.8.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn",
      "version": "11"
    },
    "runtime": {
      "name": "node",
      "onFail": "warn",
      "version": "24"
    }
  },
  "name": "starter-cf-workers",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "wg": "wrangler"
  },
  "type": "module",
  "version": "0.0.0"
}
